<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="600dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_logo"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:textColor="#000000"
                android:textSize="38sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MINEGUARD"
            android:textColor="#FAFAFA"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SISTEMA DE SEGURANÇA INDUSTRIAL"
            android:textColor="#52525B"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="48dp" />

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENDEREÇO IP DO SERVIDOR"
                android:textColor="#71717A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_ip"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ex: 192.168.1.100"
                android:textColor="#FAFAFA"
                android:textColorHint="#52525B"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PORTA"
                android:textColor="#71717A"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="5000"
                android:textColor="#FAFAFA"
                android:textColorHint="#52525B"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="number"
                android:singleLine="true"
                android:layout_marginBottom="28dp" />

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CONECTAR AO SERVIDOR"
                android:textColor="#000000"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:backgroundTint="#F97316" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesso restrito a pessoal autorizado"
            android:textColor="#3F3F46"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
