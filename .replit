modules = ["nodejs-20", "python-3.12", "bash", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 2026

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 2026
externalPort = 2026

[[ports]]
localPort = 24678
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["npm", "run", "dev"]

[userenv]

[userenv.shared]
PORT = "2026"
